<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/black"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_height="wrap_content"

        >


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Health and wellness"
            android:textSize="30sp"
            android:textAlignment="center"
            android:textColor="#A6E70D"
            android:layout_marginTop="30dp"
            android:id="@+id/title"
            android:fontFamily="serif"






            />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/image2"
            android:layout_margin="30dp"
            android:scaleType="centerCrop"
            android:id="@id/image"





            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="30dp"
            android:backgroundTint="#A6E70D"
            android:text="Healthy Recipes"
            android:fontFamily="serif"
            android:textSize="20sp"
            android:id="@+id/recipe"

            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="30dp"
            android:backgroundTint="#A6E70D"
            android:text="Nutrition Advice"
            android:fontFamily="serif"
            android:textSize="20sp"
            android:id="@+id/nutrition"
            />
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="30dp"
            android:backgroundTint="#A6E70D"
            android:text="Meditation"
            android:fontFamily="serif"
            android:textSize="20sp"
            android:id="@+id/meditation"
            />
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="30dp"
                android:backgroundTint="#A6E70D"
                android:text="Hydration Alert"
                android:fontFamily="serif"
                android:textSize="20sp"
                android:id="@+id/hydration"
                />

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="30dp"
                android:backgroundTint="#A6E70D"
                android:text="Start Exercise"
                android:fontFamily="serif"
                android:textSize="20sp"
                android:id="@+id/exercise"
                />

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="30dp"
                android:backgroundTint="#A6E70D"
                android:text="Daily Motivation"
                android:fontFamily="serif"
                android:textSize="20sp"
                android:id="@+id/motivation"

                />



    </LinearLayout>

</ScrollView>