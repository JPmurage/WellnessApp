<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black"
    android:padding="20dp"
    tools:context=".StartExercise">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Your Exercise"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:fontFamily="sans-serif-black"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="5"
        android:layout_marginTop="24dp"/>

    <!-- Motivational Tagline -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Consistency builds strength. Let’s begin!"
        android:textSize="18sp"
        android:textColor="#A6E70D"
        android:gravity="center"
        android:fontFamily="sans-serif-light"
        android:layout_marginTop="12dp"/>

    <!-- Exercise Image Banner -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:src="@drawable/main2"
        android:scaleType="centerCrop"
        android:layout_marginTop="24dp"
        android:background="@drawable/progressbar"
        android:elevation="6dp"/>

    <!-- Start Button -->
    <Button

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="START NOW"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="#A6E70D"
        android:layout_marginTop="32dp"
        android:padding="12dp"
        android:fontFamily="sans-serif-medium"
        android:elevation="4dp"/>
</LinearLayout>
